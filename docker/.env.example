# Production Environment Variables
# Copy this file to .env and update with your actual values

# Giphy API Configuration
VITE_GIPHY_API_KEY=your-giphy-api-key-here

# Jitsi Server Configuration
VITE_JITSI_DOMAIN=jitsi.spaces.justsocial.chat

# Backend and OAuth Configuration
# IMPORTANT: For production, use your actual backend domain
VITE_BACKEND_URL=https://api.yourdomain.com
VITE_BASE_URL=https://yourdomain.com

# Docker Configuration
# Port to expose on host (default: 8080)
# The service will be available at http://127.0.0.1:8080
# FRONTEND_PORT=8080
